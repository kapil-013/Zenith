rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isDepartment() {
      return isSignedIn() && getUserData().role == 'department';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId && request.resource.data.role == 'citizen');
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'departmentName', 'points', 'badges'])); 
      allow delete: if isAdmin();
    }

    match /issues/{issueId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isDepartment() && resource.data.assignedTo == getUserData().departmentName && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verificationCount', 'disputeCount', 'duplicateCount', 'confirmedResolvedCount', 'updatedAt', 'status', 'priorityScore', 'priorityReasons'])
      );
      allow delete: if isAdmin();
    }

    match /verifications/{verificationId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    match /status_updates/{updateId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
